<Window x:Class="Vet_Master.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vet Master" Height="620" Width="960"
        MinHeight="500" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Кнопка основна -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#185FA5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0C447C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка вторинна -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка небезпечна -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#C0392B"/>
            <Setter Property="BorderBrush" Value="#E57373"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Таб -->
        <Style x:Key="MainTab" TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#185FA5"/>
                                <Setter Property="Foreground" Value="#185FA5"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Внутрішній таб -->
        <Style x:Key="InnerTab" TargetType="TabItem" BasedOn="{StaticResource MainTab}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Заголовок -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="🐾  Vet Master" FontSize="16" FontWeight="Medium" Foreground="#222"/>
        </Border>

        <!-- Головні таби -->
        <TabControl x:Name="MainTabControl"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <DockPanel>
                                    <!-- Рядок табів -->
                                    <Border DockPanel.Dock="Top" Background="White"
                                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                        <TabPanel IsItemsHost="True" Margin="8,0"/>
                                    </Border>
                                    <!-- Контент -->
                                    <ContentPresenter ContentSource="SelectedContent"/>
                                </DockPanel>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Style>

            <!-- ══════════════════════════════════════
                 ТАБ 1: ТВАРИНИ
            ══════════════════════════════════════ -->
            <TabItem Header="Тварини" Style="{StaticResource MainTab}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Ліва панель: список -->
                        <ColumnDefinition Width="240" MinWidth="180"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Ліва панель ── -->
                    <Border Grid.Column="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                        <DockPanel>
                            <!-- Тулбар -->
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        Margin="8,8,8,6" >
                                <Button Content="+ Додати" Style="{StaticResource BtnPrimary}"
                                        Margin="0,0,6,0" Click="BtnAddAnimal_Click"/>
                                <TextBox x:Name="SearchBox" Width="120" FontSize="12"
                                         Padding="6,4" VerticalContentAlignment="Center"
                                         BorderBrush="#CCC" BorderThickness="1"
                                         TextChanged="SearchBox_TextChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="White" CornerRadius="5"
                                                                BorderBrush="#CCC" BorderThickness="1"
                                                                Padding="6,4">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                            <!-- Список тварин -->
                            <ListBox x:Name="AnimalListBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="AnimalListBox_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E8F0FA"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="#222"/>
                                            <TextBlock FontSize="11" Foreground="#888" Margin="0,2,0,0">
                                                <Run Text="{Binding Species}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Breed}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Розділювач -->
                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="#E8E8E8"/>

                    <!-- ── Права панель: деталі ── -->
                    <Border Grid.Column="2" Background="White">
                        <!-- Placeholder коли нічого не вибрано -->
                        <Grid>
                            <TextBlock x:Name="NoSelectionHint"
                                       Text="Оберіть тварину зі списку"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14" Foreground="#BBB"
                                       Visibility="Visible"/>

                            <!-- Панель деталей -->
                            <DockPanel x:Name="DetailPanel" Visibility="Collapsed">

                                <!-- Заголовок тварини -->
                                <Border DockPanel.Dock="Top"
                                        BorderBrush="#F0F0F0" BorderThickness="0,0,0,1"
                                        Padding="16,12">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="Редагувати"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Margin="0,0,6,0"
                                                    Click="BtnEditAnimal_Click"/>
                                            <Button Content="Видалити"
                                                    Style="{StaticResource BtnDanger}"
                                                    Click="BtnDeleteAnimal_Click"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="DetailName"
                                                       FontSize="18" FontWeight="Medium"
                                                       Foreground="#222"/>
                                            <TextBlock x:Name="DetailMeta"
                                                       FontSize="12" Foreground="#888"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Внутрішні таби -->
                                <TabControl BorderThickness="0" Background="Transparent"
                                            Padding="0">
                                    <TabControl.Style>
                                        <Style TargetType="TabControl">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TabControl">
                                                        <DockPanel>
                                                            <Border DockPanel.Dock="Top"
                                                                    BorderBrush="#F0F0F0"
                                                                    BorderThickness="0,0,0,1">
                                                                <TabPanel IsItemsHost="True" Margin="8,0"/>
                                                            </Border>
                                                            <ContentPresenter ContentSource="SelectedContent"
                                                                              Margin="0"/>
                                                        </DockPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TabControl.Style>

                                    <!-- ── Інформація ── -->
                                    <TabItem Header="Інформація" Style="{StaticResource InnerTab}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      Padding="16,14">
                                            <StackPanel>
                                                <Grid x:Name="InfoGrid">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Вид -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,12">
                                                        <TextBlock Text="ВИД" FontSize="10" Foreground="#999"
                                                                   FontWeight="Medium" Margin="0,0,0,3"/>
                                                        <TextBlock x:Name="InfoSpecies" FontSize="13" Foreground="#222"/>
                                                    </StackPanel>
                                                    <!-- Порода -->
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                                        <TextBlock Text="ПОРОДА" FontSize="10" Foreground="#999"
                                                                   FontWeight="Medium" Margin="0,0,0,3"/>
                                                        <TextBlock x:Name="InfoBreed" FontSize="13" Foreground="#222"/>
                                                    </StackPanel>
                                                    <!-- Вік -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,12">
                                                        <TextBlock Text="ВІК" FontSize="10" Foreground="#999"
                                                                   FontWeight="Medium" Margin="0,0,0,3"/>
                                                        <TextBlock x:Name="InfoAge" FontSize="13" Foreground="#222"/>
                                                    </StackPanel>
                                                    <!-- Стать -->
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                                        <TextBlock Text="СТАТЬ" FontSize="10" Foreground="#999"
                                                                   FontWeight="Medium" Margin="0,0,0,3"/>
                                                        <TextBlock x:Name="InfoSex" FontSize="13" Foreground="#222"/>
                                                    </StackPanel>
                                                    <!-- Власник -->
                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,12">
                                                        <TextBlock Text="ВЛАСНИК" FontSize="10" Foreground="#999"
                                                                   FontWeight="Medium" Margin="0,0,0,3"/>
                                                        <TextBlock x:Name="InfoOwner" FontSize="13" Foreground="#222"/>
                                                    </StackPanel>
                                                    <!-- Телефон -->
                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                                        <TextBlock Text="ТЕЛЕФОН" FontSize="10" Foreground="#999"
                                                                   FontWeight="Medium" Margin="0,0,0,3"/>
                                                        <TextBlock x:Name="InfoPhone" FontSize="13" Foreground="#222"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Медіа -->
                                                <Border Background="#F8F8F8" CornerRadius="6"
                                                        BorderBrush="#E0E0E0" BorderThickness="1"
                                                        Padding="12,10" Margin="0,4,0,0">
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right"
                                                                Content="Відкрити"
                                                                Style="{StaticResource BtnSecondary}"
                                                                Click="BtnOpenMedia_Click"/>
                                                        <StackPanel Margin="0,0,12,0">
                                                            <TextBlock Text="МЕДІА ФАЙЛ" FontSize="10"
                                                                       Foreground="#999" FontWeight="Medium"
                                                                       Margin="0,0,0,3"/>
                                                            <TextBlock x:Name="InfoMedia"
                                                                       FontSize="12" Foreground="#555"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>

                                    <!-- ── Хвороби ── -->
                                    <TabItem Header="Хвороби" Style="{StaticResource InnerTab}">
                                        <DockPanel Margin="16,12,16,12">
                                            <StackPanel DockPanel.Dock="Top"
                                                        Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Content="+ Новий запис"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Click="BtnAddRecord_Click"/>
                                            </StackPanel>
                                            <ListBox x:Name="RecordListBox"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     SelectionChanged="RecordListBox_SelectionChanged"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="6"
                                                                Padding="12,10"
                                                                Cursor="Hand">
                                                            <StackPanel>
                                                                <DockPanel>
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Text="{Binding VisitDate, StringFormat=dd.MM.yyyy}"
                                                                               FontSize="11" Foreground="#999"/>
                                                                    <TextBlock Text="{Binding Diagnosis}"
                                                                               FontSize="13" FontWeight="Medium"
                                                                               Foreground="#222"/>
                                                                </DockPanel>
                                                                <TextBlock Margin="0,4,0,0" FontSize="11"
                                                                           Foreground="#888">
                                                                    <Run Text="Скарги: "/>
                                                                    <Run Text="{Binding Complaints}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,2,0,0" FontSize="11"
                                                                           Foreground="#888">
                                                                    <Run Text="Лікування: "/>
                                                                    <Run Text="{Binding TreatmentStart, StringFormat=dd.MM.yyyy}"/>
                                                                    <Run Text=" → "/>
                                                                    <Run Text="{Binding TreatmentEnd, StringFormat=dd.MM.yyyy, TargetNullValue='не вказано'}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,4,0,0" FontSize="11"
                                                                           Foreground="#555"
                                                                           TextWrapping="Wrap">
                                                                    <Run Text="Рекомендації: " FontWeight="Medium"/>
                                                                    <Run Text="{Binding Recommendations}"/>
                                                                </TextBlock>
                                                                <!-- Кнопки редагування -->
                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,8,0,0" HorizontalAlignment="Right">
                                                                    <Button Content="Редагувати"
                                                                            Style="{StaticResource BtnSecondary}"
                                                                            Padding="8,3" FontSize="11"
                                                                            Margin="0,0,6,0"
                                                                            Tag="{Binding Id}"
                                                                            Click="BtnEditRecord_Click"/>
                                                                    <Button Content="Видалити"
                                                                            Style="{StaticResource BtnDanger}"
                                                                            Padding="8,3" FontSize="11"
                                                                            Tag="{Binding Id}"
                                                                            Click="BtnDeleteRecord_Click"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </TabItem>

                                    <!-- ── Щеплення ── -->
                                    <TabItem Header="Щеплення" Style="{StaticResource InnerTab}">
                                        <DockPanel Margin="16,12,16,12">
                                            <StackPanel DockPanel.Dock="Top"
                                                        Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Content="+ Додати щеплення"
                                                        Style="{StaticResource BtnPrimary}"
                                                        Click="BtnAddVaccination_Click"/>
                                            </StackPanel>
                                            <DataGrid x:Name="VaccinationGrid"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      RowHeaderWidth="0"
                                                      GridLinesVisibility="Horizontal"
                                                      HorizontalGridLinesBrush="#F0F0F0"
                                                      BorderThickness="1"
                                                      BorderBrush="#E0E0E0"
                                                      Background="White"
                                                      FontSize="12"
                                                      ColumnHeaderHeight="32">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Назва вакцини"
                                                                        Binding="{Binding VaccineName}"
                                                                        Width="*"/>
                                                    <DataGridTextColumn Header="Дата"
                                                                        Binding="{Binding VaccinationDate, StringFormat=dd.MM.yyyy}"
                                                                        Width="100"/>
                                                    <DataGridTemplateColumn Header="" Width="80">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="Видалити"
                                                                        Style="{StaticResource BtnDanger}"
                                                                        Padding="6,2" FontSize="10"
                                                                        Tag="{Binding Id}"
                                                                        Click="BtnDeleteVaccination_Click"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </TabItem>

                                </TabControl>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════
                 ТАБ 2: СТАТИСТИКА
            ══════════════════════════════════════ -->
            <TabItem Header="Статистика" Style="{StaticResource MainTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel MaxWidth="700" HorizontalAlignment="Left">

                        <!-- Картки з цифрами -->
                        <UniformGrid Columns="3" Margin="0,0,0,20">
                            <!-- Лікуються -->
                            <Border Background="White" BorderBrush="#E0E0E0"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="16,14" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="ЗАРАЗ ЛІКУЮТЬСЯ" FontSize="10"
                                               Foreground="#999" FontWeight="Medium"/>
                                    <TextBlock x:Name="StatActive" Text="—"
                                               FontSize="28" FontWeight="Medium"
                                               Foreground="#185FA5" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="StatActiveSub" FontSize="11"
                                               Foreground="#AAA"/>
                                </StackPanel>
                            </Border>
                            <!-- Завершили минулого місяця -->
                            <Border Background="White" BorderBrush="#E0E0E0"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="16,14" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="ЗАВЕРШИЛИ МИН. МІСЯЦЬ" FontSize="10"
                                               Foreground="#999" FontWeight="Medium"/>
                                    <TextBlock x:Name="StatFinished" Text="—"
                                               FontSize="28" FontWeight="Medium"
                                               Foreground="#0F6E56" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="StatFinishedSub" FontSize="11"
                                               Foreground="#AAA"/>
                                </StackPanel>
                            </Border>
                            <!-- Всього тварин -->
                            <Border Background="White" BorderBrush="#E0E0E0"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="ВСЬОГО ТВАРИН" FontSize="10"
                                               Foreground="#999" FontWeight="Medium"/>
                                    <TextBlock x:Name="StatTotal" Text="—"
                                               FontSize="28" FontWeight="Medium"
                                               Foreground="#444" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- По категоріям -->
                        <TextBlock Text="ПО ВИДАХ" FontSize="11" FontWeight="Medium"
                                   Foreground="#999" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="StatBySpecies">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Count}"
                                                   FontSize="12" Foreground="#666"
                                                   Width="24" TextAlignment="Right"/>
                                        <TextBlock Text="{Binding Species}"
                                                   FontSize="12" Foreground="#444"
                                                   Width="80"/>
                                        <Border Background="#E8F0FA" CornerRadius="3" Height="14">
                                            <Border Background="#185FA5" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding BarWidth}"/>
                                        </Border>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Таблиця: хто зараз лікується -->
                        <TextBlock Text="ХТО ЗАРАЗ ЛІКУЄТЬСЯ" FontSize="11"
                                   FontWeight="Medium" Foreground="#999"
                                   Margin="0,20,0,10"/>
                        <DataGrid x:Name="StatActiveGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0F0F0"
                                  BorderThickness="1"
                                  BorderBrush="#E0E0E0"
                                  Background="White"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тварина"
                                                    Binding="{Binding AnimalCard.Name}" Width="120"/>
                                <DataGridTextColumn Header="Діагноз"
                                                    Binding="{Binding Diagnosis}" Width="*"/>
                                <DataGridTextColumn Header="Початок лікування"
                                                    Binding="{Binding TreatmentStart, StringFormat=dd.MM.yyyy}"
                                                    Width="130"/>
                                <DataGridTextColumn Header="Кінець лікування"
                                                    Binding="{Binding TreatmentEnd, StringFormat=dd.MM.yyyy, TargetNullValue='—'}"
                                                    Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>