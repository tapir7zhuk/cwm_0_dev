<Window x:Class="Vet_Master.Dialogs.VaccinationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Щеплення"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="Додати щеплення"
                       FontSize="16" FontWeight="Medium"
                       Foreground="#222" Margin="0,0,0,20"/>

            <!-- Назва вакцини -->
            <TextBlock Text="НАЗВА ВАКЦИНИ" FontSize="10" FontWeight="Medium"
                       Foreground="#999" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbVaccine"
                      IsEditable="True"
                      FontSize="13" Padding="8,6"
                      BorderBrush="#CCC" Margin="0,0,0,12">
                <ComboBoxItem Content="Сказ (Nobivac Rabies)"/>
                <ComboBoxItem Content="Панлейкопенія (Felocell)"/>
                <ComboBoxItem Content="Кальцивіроз / Герпесвірус"/>
                <ComboBoxItem Content="Чумка (Nobivac DHPPi)"/>
                <ComboBoxItem Content="Лептоспіроз"/>
                <ComboBoxItem Content="Парвовірус"/>
                <ComboBoxItem Content="Коронавірус"/>
            </ComboBox>

            <!-- Дата -->
            <TextBlock Text="ДАТА ЩЕПЛЕННЯ" FontSize="10" FontWeight="Medium"
                       Foreground="#999" Margin="0,0,0,4"/>
            <DatePicker x:Name="DpDate"
                        FontSize="13"
                        BorderBrush="#CCC"
                        Margin="0,0,0,20"
                        xmlns:system="clr-namespace:System;assembly=mscorlib"
                        SelectedDate="{x:Static system:DateTime.Today}"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Скасувати"
                        Margin="0,0,10,0"
                        Padding="20,8" FontSize="13"
                        Cursor="Hand"
                        Background="White" Foreground="#444"
                        BorderBrush="#CCC" BorderThickness="1"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Зберегти"
                        Padding="20,8" FontSize="13"
                        Cursor="Hand"
                        Background="#185FA5" Foreground="White"
                        BorderThickness="0"
                        Click="BtnSave_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>